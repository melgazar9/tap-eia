# EIA Configuration
# Copy this file to .env and fill in your actual values

# Required: EIA API key (register at https://www.eia.gov/opendata/)
EIA_API_KEY=your_eia_api_key_here

# Optional: Top-level routes to pull (comma-separated, or "*" for all)
# TAP_EIA_ROUTES=natural-gas,petroleum,electricity

# Optional: Earliest data period to pull (YYYY-MM-DD)
# TAP_EIA_START_DATE=2020-01-01

# Optional: Latest data period to pull (YYYY-MM-DD)
# TAP_EIA_END_DATE=2026-01-01

# Optional: Frequencies to pull (comma-separated, or "*" for all)
# TAP_EIA_FREQUENCIES=monthly,annual

# Optional: Max requests per minute (default: 30)
# TAP_EIA_MAX_REQUESTS_PER_MINUTE=30

# Optional: Records per API page (default: 5000, max: 5000)
# TAP_EIA_PAGE_SIZE=5000

# Optional: Strict mode - fail on any API error (default: false)
# TAP_EIA_STRICT_MODE=false
